# ── Supabase ──────────────────────────────────────────────────
# Obtenir ces valeurs dans Supabase > Project Settings > API

# URL du projet (ex: https://xxxx.supabase.co)
SUPABASE_URL=https://xxxx.supabase.co

# Clé anonymique publique (anon public key)
SUPABASE_KEY=eyJ...

# ── Blog ──────────────────────────────────────────────────────
# URL publique du blog (sans slash final)
NUXT_PUBLIC_SITE_URL=https://blog.masia-antoine.fr
